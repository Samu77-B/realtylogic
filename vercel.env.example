# Copy these to Vercel → Project → Settings → Environment Variables
# Use the same values as your local .env file.

DATABASE_URI=postgresql://USER:PASSWORD@ep-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require
PAYLOAD_SECRET=your-long-random-secret

# Add Vercel Blob storage to the project first — Vercel auto-generates this token.
BLOB_READ_WRITE_TOKEN=
