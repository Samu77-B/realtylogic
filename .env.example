# Neon Postgres (recommended) — Project Settings → Connection string → Pooled connection
DATABASE_URI=postgresql://USER:PASSWORD@ep-xxxx.eu-west-2.aws.neon.tech/neondb?sslmode=require

# Payload auth/session signing — use a long random string in production
PAYLOAD_SECRET=your-secret-key-change-in-production

# Vercel Blob (optional locally; auto-set on Vercel after adding Blob storage to the project)
# BLOB_READ_WRITE_TOKEN=

# Realty AI (Vercel AI Gateway) — on Vercel, OIDC is preferred; locally you can set:
# AI_GATEWAY_API_KEY=
